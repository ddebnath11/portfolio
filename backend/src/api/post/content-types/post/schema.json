      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "category": {
      "type": "string"
    },
    "date": {
      "type": "datetime"
    },
    "postcontent": {
      "type": "blocks"
    },
    "featured": {
      "type": "boolean"
    },
    "postcoverimg": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    }
  }
