---
---

<div class="fixed bottom-6 left-0 w-full z-50 pointer-events-none px-4 lg:px-8">
  
  <div class="flex flex-row items-center justify-between w-full gap-4">
    
    <div class="flex items-center gap-2.5 bg-brand-bg/80 backdrop-blur-md border border-brand-secondary/10 px-3 py-1.5 rounded-full shadow-lg pointer-events-auto transition-all duration-300">
      <span class="text-[10px] font-medium tracking-[0.05em] text-brand-secondary/40 font-primary uppercase select-none mr-1 pl-1">
        theme
      </span>

      <button
        data-theme-set="dark"
        class="theme-btn relative w-4 h-4 rounded-full border border-transparent transition-all duration-200 hover:scale-110 active:scale-95"
        aria-label="Switch to Dark Theme"
      ></button>

      <button
        data-theme-set="github"
        class="theme-btn relative w-4 h-4 rounded-full border border-transparent transition-all duration-200 hover:scale-110 active:scale-95"
        aria-label="Switch to GitHub Theme"
      ></button>

      <button
        data-theme-set="skynet"
        class="theme-btn relative w-4 h-4 rounded-full border border-transparent transition-all duration-200 hover:scale-110 active:scale-95"
        aria-label="Switch to Cyberpunk Theme"
      ></button>
    </div>

    <div class="flex items-center gap-1.5 bg-brand-bg/80 backdrop-blur-md border border-brand-secondary/10 px-3 py-1.5 rounded-full shadow-lg pointer-events-auto transition-all duration-300">
      <span class="text-[10px] font-medium tracking-[0.05em] text-brand-secondary/40 font-primary uppercase select-none mr-1.5 pl-1">
        audio
      </span>

      <button
        id="audio-toggle-btn"
        data-audio-state="off"
        class="audio-btn relative px-3 py-0.5 rounded-full text-xs font-primary lowercase tracking-tight border border-transparent transition-all duration-200 hover:scale-105 active:scale-95"
        aria-label="Toggle Background Audio"
      >
        off
      </button>
    </div>

  </div>
</div>

<style>
  :root:not([data-theme]) button[data-theme-set="dark"],
  :root[data-theme="dark"] button[data-theme-set="dark"],
  :root[data-theme="github"] button[data-theme-set="github"],
  :root[data-theme="skynet"] button[data-theme-set="skynet"] {
    background-color: var(--color-brand-primary);
    border-color: var(--color-brand-primary);
  }

  button#audio-toggle-btn[data-audio-state="on"] {
    background-color: var(--color-brand-secondary);
    color: var(--color-brand-bg);
    border-color: var(--color-brand-secondary);
    font-weight: 600;
  }

  /* 🎨 Circular indicator baseline backgrounds */
  button[data-theme-set="dark"] { background-color: rgba(255, 255, 255, 0.2); }
  button[data-theme-set="github"] { background-color: rgba(36, 41, 47, 0.4); border-color: rgba(var(--color-brand-secondary), 0.2); }
  button[data-theme-set="skynet"] { background-color: rgba(0, 255, 204, 0.2); }

  .theme-btn:hover {
    border-color: var(--color-brand-secondary);
  }
  
  .audio-btn {
    color: rgba(var(--color-brand-secondary), 0.6);
  }
  .audio-btn:hover {
    color: var(--color-brand-secondary);
    background-color: rgba(var(--color-brand-secondary), 0.05);
  }
</style>

<script>
  function initThemeSwitcher() {
    const buttons = document.querySelectorAll('.theme-btn');
    
    const savedTheme = localStorage.getItem('portfolio-theme');
    if (savedTheme) {
      document.documentElement.setAttribute('data-theme', savedTheme);
    }

    buttons.forEach(button => {
      button.addEventListener('click', () => {
        const selectedTheme = button.getAttribute('data-theme-set');
        if (!selectedTheme) return;

        document.documentElement.setAttribute('data-theme', selectedTheme);
        localStorage.setItem('portfolio-theme', selectedTheme);
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initThemeSwitcher);
  document.addEventListener('astro:after-swap', initThemeSwitcher);
</script>