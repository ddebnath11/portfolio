  </div>

<a class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-10 text-brand-secondary transition-all duration-300 hover:opacity-80 cursor-pointer"

href="/"
>
  
  <svg 
    class="w-8 h-8 md:h-8" 
    viewBox="0 0 348 229" 
    fill="none" 
    xmlns="http://www.w3.org/2000/svg"
  >
    <g>
      <path d="M172.885 0H240.843C264.921 0 284.835 4.915 300.584 14.746C316.446 24.461 328.314 37.935 336.189 55.168C344.063 72.401 348 92.12 348 114.326C348 136.648 344.063 156.425 336.189 173.658C328.314 190.891 316.446 204.423 300.584 214.254C284.835 224.085 264.921 229 240.843 229H172.885V0ZM223.896 45.973V183.026H236.22C249.116 183.026 259.786 180.077 268.231 174.179C276.676 168.164 283.009 160.011 287.232 149.718C291.568 139.308 293.736 127.627 293.736 114.674C293.736 101.605 291.625 89.923 287.403 79.63C283.295 69.22 276.961 61.009 268.402 54.995C259.843 48.981 249.116 45.973 236.22 45.973H223.896Z" fill="currentColor"/>
      
      <path d="M66.369 229C52.937 229 41.255 225.838 31.322 219.513C21.3892 213.079 13.6575 204.519 8.1267 193.832C2.7089 183.037 0 171.096 0 158.01C0 144.924 2.7089 133.038 8.1267 122.352C13.6575 111.556 21.3892 102.941 31.322 96.507C41.255 90.073 52.937 86.857 66.369 86.857C75.286 86.857 83.187 88.219 90.072 90.946C96.957 93.563 102.544 96.725 106.833 100.433C111.122 104.032 113.718 107.358 114.621 110.411V0H166.091V225.298H115.129V203.319C112.985 207.354 109.486 211.389 104.632 215.423C99.778 219.349 94.079 222.566 87.532 225.074C80.985 227.692 73.931 229 66.369 229ZM82.114 189.907C88.322 189.907 93.853 188.543 98.707 185.817C103.673 183.091 107.567 179.329 110.389 174.531C113.21 169.623 114.621 164.117 114.621 158.01C114.621 151.903 113.21 146.451 110.389 141.653C107.567 136.746 103.673 132.929 98.707 130.203C93.853 127.367 88.322 125.95 82.114 125.95C76.132 125.95 70.714 127.367 65.861 130.203C61.12 132.929 57.339 136.746 54.517 141.653C51.808 146.451 50.454 151.903 50.454 158.01C50.454 164.117 51.808 169.623 54.517 174.531C57.339 179.329 61.12 183.091 65.861 185.817C70.714 188.543 76.132 189.907 82.114 189.907Z" fill="currentColor"/>
      
      <rect x="44.615" y="123.995" width="87" height="72.6098" fill="currentColor"/>
      <rect x="190.731" y="34.629" width="113.769" height="151.922" fill="currentColor"/>
      <rect x="114.885" y="0" width="51.3077" height="229" fill="currentColor"/>
    </g>
  </svg>

</a>

 

  <div class="relative z-50 flex flex-row gap-4">

    <button 
      id="custom-hamburger"
      class="relative group focus:outline-none"
      data-state="closed"
      aria-label="Toggle Menu"
    >
      <div class="cursor-pointer relative flex items-center justify-center rounded-full w-11 h-11 bg-transparent border border-brand-secondary/0 hover:border-brand-secondary/20 transition-all duration-300 ease-out hover:scale-105 group-[[data-state=open]]:ring-4 group-[[data-state=open]]:ring-brand-secondary/10">

        <div class="relative flex flex-col justify-between w-5 h-3.5 transition-all duration-300 overflow-hidden">
          
          <div class="bg-brand-secondary h-[1.5px] w-full transition-all duration-300 origin-left group-[[data-state=open]]:translate-x-8"></div>
          <div class="bg-brand-secondary h-[1.5px] w-full transition-all duration-300 group-[[data-state=open]]:translate-x-8 delay-75"></div>
          <div class="bg-brand-secondary h-[1.5px] w-full transition-all duration-300 origin-left group-[[data-state=open]]:translate-x-8 delay-150"></div>

          <div class="absolute top-1/2 left-1/2 -translate-y-1/2 -translate-x-[40px] group-[[data-state=open]]:-translate-x-1/2 flex items-center justify-center w-5 h-5 transition-all duration-500">
            <div class="absolute bg-brand-secondary h-[1.5px] w-5 transition-all duration-500 rotate-0 delay-300 group-[[data-state=open]]:rotate-45"></div>
            <div class="absolute bg-brand-secondary h-[1.5px] w-5 transition-all duration-500 -rotate-0 delay-300 group-[[data-state=open]]:-rotate-45"></div>
          </div>

        </div>
      </div>
    </button>
  </div>   
</div>

<div 
  id="menu-overlay" 
  class="fixed inset-0 z-40 bg-brand-bg/95 backdrop-blur-lg flex flex-col items-center justify-center opacity-0 pointer-events-none transition-all duration-500 ease-in-out"
>  

  <nav class="flex flex-col items-center gap-6 text-3xl md:text-4xl font-secondary font-medium tracking-tight">

    <a href="/" class="text-brand-secondary/60 transform transition-all duration-300 hover:text-brand-primary hover:translate-y-[-2px]">Home</a>

    <a href="/projects/" class="text-brand-secondary/60 transform transition-all duration-300 hover:text-brand-primary hover:translate-y-[-2px] ">Projects</a>

    <a href="/av/" class="text-brand-secondary/60 transform transition-all duration-300 hover:text-brand-primary hover:translate-y-[-2px] ">Audiovisual</a>

    <a href="/blog/" class="text-brand-secondary/60 transform transition-all duration-300 hover:text-brand-primary hover:translate-y-[-2px] ">Blog</a>
    
  </nav>

  <div class="absolute top-28 left-0 right-0 px-8 pointer-events-none flex flex-col items-center gap-4">
    <p class="text-[10px] uppercase tracking-[0.15em] text-brand-secondary/40 text-center font-secondary font-medium">
      {footnote}
    </p>

  </div>

  <Controls />
  
</div>

<script>
  let inactivityTimeout: number;
  const INACTIVITY_LIMIT = 10000; // 10 seconds
  const activityEvents = ['mousemove', 'mousedown', 'touchstart', 'keydown', 'scroll'];

  // --- CORE INITIALIZATION ENGINE ---
  function initNavbar() {
    const menuBtn = document.getElementById('custom-hamburger');
    const overlay = document.getElementById('menu-overlay');
    const navbar = document.getElementById('main-navbar');

    if (!menuBtn || !overlay || !navbar) return;

    // 1. Clean up any stale event listeners before adding new ones
    menuBtn.removeEventListener('click', toggleMenu);
    menuBtn.addEventListener('click', toggleMenu);

    // 2. Setup/Reset the Scroll Inactivity Tracker
    setupInactivityTracker(navbar, menuBtn);
  }

  // --- OVERLAY CODE ENGINE ---
  function toggleMenu(event: Event) {
    const menuBtn = event.currentTarget as HTMLElement;
    const overlay = document.getElementById('menu-overlay');
    if (!menuBtn || !overlay) return;

    const isOpen = menuBtn.getAttribute('data-state') === 'open';

    if (!isOpen) {
      menuBtn.setAttribute('data-state', 'open');
      overlay.classList.remove('opacity-0', 'pointer-events-none');
      overlay.classList.add('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = 'hidden';
    } else {
      closeMenu(menuBtn, overlay);
    }
  }

  function closeMenu(menuBtn: HTMLElement, overlay: HTMLElement) {
    menuBtn.setAttribute('data-state', 'closed');
    overlay.classList.remove('opacity-100', 'pointer-events-auto');
    overlay.classList.add('opacity-0', 'pointer-events-none');
    document.body.style.overflow = '';
  }

  // --- NAVBAR INACTIVITY TRACKER ---
  function setupInactivityTracker(navbar: HTMLElement, menuBtn: HTMLElement) {
    // Reset global timer state
    window.clearTimeout(inactivityTimeout);

    function hideNavbar() {
      // Never auto-hide the navbar if the overlay menu is actively open
      if (menuBtn.getAttribute('data-state') === 'open') {
        resetTimer();
        return;
      }
      navbar.classList.add('-translate-y-full');
    }

    function showNavbar() {
      navbar.classList.remove('-translate-y-full');
    }

    function resetTimer() {
      showNavbar();
      window.clearTimeout(inactivityTimeout);
      inactivityTimeout = window.setTimeout(hideNavbar, INACTIVITY_LIMIT);
    }

    // Strip out active listeners from past pages to prevent cross-page duplication leaks
    activityEvents.forEach(event => {
      window.removeEventListener(event, resetTimer);
      window.addEventListener(event, resetTimer, { passive: true });
    });

    // Run immediately on page target layout resolution
    resetTimer();
  }

  // --- ASTRO SPA LIFECYCLE MANAGEMENT ---
  // astro:page-load handles both the initial execution on raw HTTP hit
  // AND fires cleanly after every single SPA View Transition swap.
  document.addEventListener('astro:page-load', initNavbar);

  // Close the overlay automatically if a user clicks an internal link
  document.addEventListener('astro:before-swap', () => {
    const menuBtn = document.getElementById('custom-hamburger');
    const overlay = document.getElementById('menu-overlay');
    if (menuBtn && overlay && menuBtn.getAttribute('data-state') === 'open') {
      closeMenu(menuBtn, overlay);
    }
    window.clearTimeout(inactivityTimeout);
  });
</script>