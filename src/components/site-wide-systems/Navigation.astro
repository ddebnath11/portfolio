---
/* IMPORTS */
import '../../styles/global.css';
import { Image } from 'astro:assets';
import Logo from '../assets/logo-main.svg';
import Controls from './Controls.astro';
import ButtonFilled from '../buttons/ButtonFilled.astro';


interface Props {
  pill: string;
  footnote?: string;
}

const { pill,
  footnote = "DIPTANGSHU DEBNATH'S PORTFOLIO"
