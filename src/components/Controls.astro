---
/* src/components/Controls.astro */
---

<div class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 pointer-events-none">
  
  <div class="flex items-center gap-2 bg-brand-bg/80 backdrop-blur-md border border-brand-secondary/10 px-4 py-2 rounded-full shadow-lg pointer-events-auto transition-all duration-300">
    
    <span class="text-[11px] font-medium tracking-[0.05em] text-brand-secondary/40 font-primary uppercase select-none mr-2">
      theme
    </span>

    <button
      data-theme-set="dark"
      class="theme-btn relative px-3 py-1 rounded-full text-xs font-primary lowercase tracking-tight border border-transparent transition-all duration-200 hover:scale-105 active:scale-95"
      aria-label="Switch to Dark Theme"
    >
      dark
    </button>

    <button
      data-theme-set="light"
      class="theme-btn relative px-3 py-1 rounded-full text-xs font-primary lowercase tracking-tight border border-transparent transition-all duration-200 hover:scale-105 active:scale-95"
      aria-label="Switch to Light Theme"
    >
      light
    </button>

    <button
      data-theme-set="cyberpunk"
      class="theme-btn relative px-3 py-1 rounded-full text-xs font-primary lowercase tracking-tight border border-transparent transition-all duration-200 hover:scale-105 active:scale-95"
      aria-label="Switch to Cyberpunk Theme"
    >
      cyber
    </button>

  </div>
</div>

<style>
  /* 🎯 Active Theme Button Styling Layer */
  /* When the matching theme attribute is active on the html root, highlight its button */
  :root:not([data-theme]) button[data-theme-set="dark"],
  :root[data-theme="dark"] button[data-theme-set="dark"],
  :root[data-theme="light"] button[data-theme-set="light"],
  :root[data-theme="cyberpunk"] button[data-theme-set="cyberpunk"] {
    background-color: var(--color-brand-secondary);
    color: var(--color-brand-bg);
    border-color: var(--color-brand-secondary);
    font-weight: 600;
  }

  /* Unselected button states fallback color mappings */
  .theme-btn:not(:disabled) {
    color: rgba(var(--color-brand-secondary), 0.6);
  }
  .theme-btn:hover {
    color: var(--color-brand-secondary);
    background-color: rgba(var(--color-brand-secondary), 0.05);
  }
</style>

<script>
  function initThemeSwitcher() {
    const buttons = document.querySelectorAll('.theme-btn');
    
    // Check for an existing saved choice in localStorage on mount
    const savedTheme = localStorage.getItem('portfolio-theme');
    if (savedTheme) {
      document.documentElement.setAttribute('data-theme', savedTheme);
    }

    buttons.forEach(button => {
      button.addEventListener('click', () => {
        const selectedTheme = button.getAttribute('data-theme-set');
        if (!selectedTheme) return;

        // Apply the setting directly to the layout shell root
        document.documentElement.setAttribute('data-theme', selectedTheme);
        // Persist across browser reloads
        localStorage.setItem('portfolio-theme', selectedTheme);
      });
    });
  }

  // Bootstrap structural engine hooks for standard layout loads and Astro View Transitions
  document.addEventListener('DOMContentLoaded', initThemeSwitcher);
  document.addEventListener('astro:after-swap', initThemeSwitcher);
</script>