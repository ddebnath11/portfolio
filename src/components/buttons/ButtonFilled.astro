---
interface Props {
  buttonAction: string;
  url?: string;
}

const { buttonAction, url } = Astro.props;
---
<a 
  href={url}
  class="inline-flex items-center justify-center  rounded-full bg-brand-primary text-brand-tertiary cursor-pointer transform transition-all duration-300 text-xs font-medium no-underline hover:text-brand-secondary hover:bg-brand-primary/70  md:text-sm   lg:text-[16px] p-4"
>
  {buttonAction}
</a>