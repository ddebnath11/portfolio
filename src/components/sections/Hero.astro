---
import { Image } from 'astro:assets';
import downArrow from '../../assets/downarrow.svg'
import CTA from '../buttons/CTA.astro';
import dDImg from '/dDimg.webp'
import CTAoutline from '../buttons/CTAoutline.astro';
---
<div class="p-5 lg:px-30">
  <div class="w-full flex flex-col items-center justify-start text-center gap-6 md:gap-8 pt-28 md:pt-24 pb-12">

    <div class="animate-blur-in flex flex-col items-center justify-start gap-6 md:gap-8">
      <div class="flex flex-col gap-6 md:gap-8 items-center justify-start">
            <div 
        id="ist-clock"
        class="border border-brand-secondary/10 text-xs p-2 px-3 rounded-full tracking-widest text-brand-secondary"
      >
        --:-- IST
      </div>

            <div class="h-[150px] w-[150px] flex flex-col lg:h-[180px] lg:w-[180px]">
              <img src="/char-happy.svg">
            </div>
      </div>

      <h1 class="text-4xl md:text-6xl lg:text-6xl text-brand-secondary font-primary tracking-[-0.03em] leading-normal font-bold">
        Hello! I'm <span class="text-brand-primary">Diptangshu</span>
      </h1>
    </div>

    <p class="font-secondary text-sm text-brand-secondary/90 md:text-sm animate-reveal-up md:text-[16px] lg:text-[20px]">
      I'm a Software Developer and Artist based in Kolkata, India.
    </p>
    
    <div class="flex flex-row gap-2 lg:gap-4">
        <CTA buttonAction='View Projects' url="/projects" shortcut='Shift + P'/>

        <CTAoutline href="https://github.com/ddebnath11" ariaLabel="Visit my GitHub profile">
            <svg class="w-5 h-5 md:w-6 md:h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
              <path d="M9 18c-4.51 2-5-2-7-2" />
            </svg>
        </CTAoutline>

        <CTAoutline href="https://www.linkedin.com/in/diptangshu-debnath-362326273/" ariaLabel="Visit my LinkedIn profile">
            <svg class="w-5 h-5 md:w-6 md:h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
              <rect x="2" y="9" width="4" height="12" />
              <circle cx="4" cy="4" r="2" />
            </svg>
         </CTAoutline>
    </div>
  </div>
</div>

<script>
  function updateISTClock() {
    const clockElement = document.getElementById('ist-clock');
    if (!clockElement) return;

    const options: Intl.DateTimeFormatOptions = {
      timeZone: 'Asia/Kolkata',
      hour: '2-digit',
      minute: '2-digit',
      hour12: true
    };

    const now = new Date();
    const istTimeString = now.toLocaleTimeString('en-US', options);
    clockElement.textContent = `${istTimeString} IST`;
  }

  updateISTClock();
  setInterval(updateISTClock, 1000);
</script>

