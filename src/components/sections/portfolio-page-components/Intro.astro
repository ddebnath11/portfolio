---
import CTA from "../../buttons/CTA.astro";
import CTAoutline from "../../buttons/CTAoutline.astro";
import ButtonFilled from "../../buttons/ButtonFilled.astro"
---


    <div class="w-full flex flex-col text-left border border-brand-secondary/20 rounded-2xl gap-6">

      <div class="animate-blur-in flex flex-col p-6 gap-6 md:gap-6">

        <div class="flex flex-col gap-3">

        <h1 class="text-3xl md:text-4xl lg:text-4xl text-brand-secondary font-primary tracking-[-0.03em] leading-normal">
           Hey! I'm Diptangshu Debnath 👋
        </h1>

        <p class="font-secondary text-sm text-brand-secondary md:text-sm lg:text-[20px] md:text-[16px] leading-8 lg:leading-8">
            I'm a <span class="underline decoration-brand-primary decoration-1 underline-offset-4 decoration-dashed text-brand-primary">Software Developer</span> based in Kolkata, India. I bridge the gap between art and engineering.
        </p>
        </div>
        
        <div class="flex flex-row gap-2">
        
        <ButtonFilled buttonAction="View CV"/>

        <CTAoutline href="https://github.com/ddebnath11" ariaLabel="Visit my GitHub profile">
              <svg class="w-5 h-5 md:w-6 md:h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                <path d="M9 18c-4.51 2-5-2-7-2" />
              </svg>
        </CTAoutline>

        </div>

        




      </div>



    </div>


