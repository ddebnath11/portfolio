---
import Layout from '../../layouts/Layout.astro';
import ButtonFilled from '../../components/buttons/ButtonFilled.astro';

import { Code } from 'astro:components';
import { fetchFromStrapi } from '../../lib/strapi';

interface Project {
  id: number;
  documentId: string;
  title: string;
  slug: string;
  description: string;
  category: string;
  project_content: any[]; 
}

export async function getStaticPaths() {
  // 🛰️ FIXED: Endpoint changed from 'posts' to 'projects' to fetch the correct dataset
  const projects = await fetchFromStrapi<Project[]>({ endpoint: 'projects' }) || [];
  
  return projects.map((project) => ({
    params: { slug: project.slug }, 
    props: { project },             
  }));
}

const { project } = Astro.props;
---

<Layout title={project.title} pill="project">
  <article class="w-full max-w-3xl mx-auto px-5 pb-24 pt-32 font-secondary">
    
    <header class="flex flex-col gap-4 pb-8 border-b border-brand-secondary/10 mb-8">
      <div class="flex items-center gap-2 text-sm font-primary uppercase tracking-wider text-brand-primary">
        <span>{project.category}</span>
      </div>
      
      <h1 class="text-3xl md:text-5xl font-accent font-bold tracking-tight text-brand-secondary leading-tight">
        {project.title}
      </h1>
      
      <p class="text-base md:text-lg text-brand-secondary/60 font-light italic leading-relaxed">
        {project.description}
      </p>
    </header>

    <div class="prose max-w-none flex flex-col gap-6 text-brand-secondary/90 text-sm md:text-base leading-relaxed">
      {project.project_content?.map((block: any) => {
        
        // Handle Paragraphs
        if (block.type === 'paragraph') {
          return (
            <p class="font-blog text-[16px] lg:text-[20px]">
              {block.children?.map((child: any) => {
                if (child.bold) return <strong class="font-bold text-brand-secondary">{child.text}</strong>;
                if (child.italic) return <em class="italic">{child.text}</em>;
                if (child.type === 'link') {
                  const linkText = child.children?.map((c: any) => c.text).join('') || '';
                  return (
                    <a 
                      href={child.url} 
                      target={child.url.startsWith('http') ? '_blank' : '_self'}
                      rel="noopener noreferrer"
                      class="text-brand-primary underline decoration-brand-primary/30 hover:decoration-brand-primary transition-all duration-200"
                    >
                      {linkText}
                    </a>
                  );
                }

                if (child.code) {
                  return <code class="px-1.5 py-0.5 bg-brand-secondary/5 border border-brand-secondary/10 rounded font-mono text-[14px] lg:text-[16px] text-brand-primary">{child.text}</code>;
                }

                return child.text;
              })}
            </p>
          );
        }

        // Handle Headings (H1 - H6)
        if (block.type === 'heading') {
          const headingText = block.children?.map((c: any) => c.text).join('') || '';
          if (block.level === 1) return <h1 class="text-3xl font-accent font-bold mt-6 text-brand-secondary lg:text-[32px]">{headingText}</h1>;
          if (block.level === 2) return <h2 class="text-2xl font-accent font-bold mt-6 text-brand-secondary lg:text-[28px]">{headingText}</h2>;
          if (block.level === 3) return <h3 class="text-xl font-accent font-bold mt-4 text-brand-secondary lg:text-[24px]">{headingText}</h3>;
          return <h4 class="text-lg font-accent font-bold mt-4 text-brand-secondary lg:text-[20px]">{headingText}</h4>;
        }

        // Handle Bulleted Lists
        if (block.type === 'list' && block.format === 'unordered') {
          return (
            <ul class="list-disc list-inside pl-4 flex flex-col gap-2 font-light text-[16px] lg:text-[18px]">
              {block.children?.map((listItem: any) => (
                <li>{listItem.children?.map((c: any) => c.text).join('')}</li>
              ))}
            </ul>
          );
        }

        // Handle Numbered Lists
        if (block.type === 'list' && block.format === 'ordered') {
          return (
            <ol class="list-decimal list-inside pl-4 flex flex-col gap-2 font-light text-[16px] lg:text-[18px]">
              {block.children?.map((listItem: any) => (
                <li>{listItem.children?.map((c: any) => c.text).join('')}</li>
              ))}
            </ol>
          );
        }

        // Handle Standalone Code Blocks
        if (block.type === 'code') {
          const codeText = block.children?.map((c: any) => c.text).join('') || '';
          
          return (
            <div class="not-prose code-block-wrapper relative group border border-brand-secondary/10 rounded-lg overflow-hidden bg-[#24292e]">
              <div class="flex items-center justify-between px-4 py-1.5 bg-brand-secondary/5 border-b border-brand-secondary/10 text-[10px] uppercase font-mono tracking-wider text-brand-secondary/40">
                <span>{block.language || "code"}</span>
                <button 
                  class="copy-btn hover:text-brand-primary transition-colors duration-200 flex items-center gap-1 py-1 px-2 rounded hover:bg-brand-secondary/5"
                  data-code={codeText}
                >
                  Copy
                </button>
              </div>

              {/* 🏝️ FIXED: Removed the extra padding container wrapper that caused the double box glitch */}
              <Code code={codeText} lang={block.language || "javascript"} theme="github-dark" />
            </div>
          );
        }

        // Handle Quote Blocks
        if (block.type === 'quote') {
          const quoteText = block.children?.map((c: any) => c.text).join('') || '';
          return (
            <blockquote class="border-l-2 border-brand-primary pl-4 italic text-brand-secondary/70 my-4 text-[16px] lg:text-[18px]">
              <p>{quoteText}</p>
            </blockquote>
          );
        }

        return null;
      })}
    </div>

    {/* 📦 FIXED: Moved this layout component safely back inside the main article container bounds */}
    <div class="pt-8">
      <ButtonFilled buttonAction='Back to All Projects' url="/projects" />
    </div>

  </article>
</Layout>

<script>
  function setupCopyButtons() {
    // 🔍 FIXED: Target the buttons directly via attribute since Astro's <Code> component generates your raw code blocks now!
    const copyButtons = document.querySelectorAll('.copy-btn');

    copyButtons.forEach((btn) => {
      // Avoid stacking script event listeners on multi-swaps
      if (btn.getAttribute('data-listener') === 'true') return;
      btn.setAttribute('data-listener', 'true');

      btn.addEventListener('click', async () => {
        const codeToCopy = btn.getAttribute('data-code') || "";
        try {
          await navigator.clipboard.writeText(codeToCopy);
          const originalText = btn.textContent;
          btn.textContent = "Copied! ✓";
          btn.classList.add('text-brand-primary');
          
          setTimeout(() => {
            btn.textContent = originalText;
            btn.classList.remove('text-brand-primary');
          }, 2000);
        } catch (err) {
          console.error('Failed to copy text: ', err);
        }
      });
    });
  }

  setupCopyButtons();
  document.addEventListener('astro:after-swap', setupCopyButtons);
</script>

<style is:global>
  /* 🎨 Clean global presentation modifiers for component structures */
  .code-block-wrapper pre {
    background-color: transparent !important;
    margin: 0 !important;
    padding: 1rem !important;
    font-size: 14px !important;
    overflow-x: auto !important;
  }
  @media (min-width: 1024px) {
    .code-block-wrapper pre {
      font-size: 16px !important;
    }
  }

  /* Structural headings configuration overrides */
  .prose h1, .prose h2, .prose h3, .prose h4 {
    color: currentColor !important;
  }

  .prose code::before,
  .prose code::after {
    content: "" !important;
  }
</style>