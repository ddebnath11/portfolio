---
import ButtonFilled from '../components/buttons/ButtonFilled.astro';
import ButtonOutline from '../components/buttons/ButtonOutline.astro';
import Layout from '../layouts/Layout.astro';

import { fetchFromStrapi } from '../lib/strapi';

interface Post {
  id: number;
  documentId: string; 
  title: string;
  slug: string;
  description: string;
  category: string;
  date: string;         
  postcontent: any[];   
  featured: boolean;
}

// 1. Fetch posts from Strapi
const posts = await fetchFromStrapi<Post[]>({ endpoint: 'posts' }) || [];

// 2. Format dates, add a dynamic reading time estimation fallback, and sort by newest date
const formattedPosts = posts.map(post => {
  // Rough reading time calculation based on character count estimation
  const characterCount = JSON.stringify(post.postcontent || '').length;
  const words = Math.max(1, Math.floor(characterCount / 6)); 
  const readTimeMin = Math.max(1, Math.ceil(words / 200));

  return {
    ...post,
    date: new Date(post.date).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric'
    }),
    readTime: `${readTimeMin} min read`
  };
}).sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

// 3. Extract featured post and separate archive lists
const featuredPost = formattedPosts.find(post => post.featured) || formattedPosts[0];
const archivePosts = featuredPost 
  ? formattedPosts.filter(post => post.documentId !== featuredPost.documentId)
  : formattedPosts;

// 4. Generate unique dynamic category lists for navigation filters
const categories = ['all', ...new Set(formattedPosts.map(post => post.category).filter(Boolean))];
---

<Layout title="Diptangshu Debnath's Blog" pill="blog">
  <main class="w-full mx-auto px-5 lg:px-30 pb-24 pt-32">
    
    <div class="flex flex-col gap-4 pb-8 border-b border-brand-secondary/10 lg:gap-6 items-center text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl  font-accent font-bold tracking-tight text-brand-secondary">
        My Blog
      </h1>
      <p class="text-sm md:text-base text-brand-secondary/80 font-secondary font-light max-w-xl leading-relaxed md:text-[16px] lg:text-[20px]">
        This is where you'll find my thoughts and the lessons I learnt. 
      </p>
       
      <div class="flex flex-row gap-2 items-left lg:gap-4">
        <ButtonFilled buttonAction='Subscribe' />
        <ButtonOutline buttonAction='Visit Notebook' />
      </div>
    </div>

    <div class="w-full py-8 border-b border-brand-secondary/10 flex flex-col md:flex-row items-stretch md:items-center justify-between gap-6">
      
      <div class="relative w-full md:max-w-xs">
        <input 
          type="text" 
          id="blog-search" 
          placeholder="search entries..." 
          class="w-full bg-brand-secondary/5 border border-brand-secondary/20 rounded-lg px-4 py-2 text-sm font-secondary font-light text-brand-secondary placeholder-brand-secondary/40 focus:outline-none focus:border-brand-primary transition-colors duration-200"
        />
      </div>

      <div class="flex flex-wrap items-center gap-2" id="filter-pill-container">
        {categories.map((category) => (
          <button
            data-category={category}
            class="filter-btn px-3 py-1 text-xs font-mono uppercase tracking-wider rounded-md border transition-all duration-300 bg-brand-secondary/5 border-brand-secondary/10 text-brand-secondary/60 data-[active=true]:border-brand-primary data-[active=true]:text-brand-primary"
            data-active={category === "all" ? "true" : "false"}
          >
            {category}
          </button>
        ))}
      </div>
    </div>
    
      <div id="blog-posts-container" class="w-full max-w-6xl mx-auto flex flex-col items-stretch gap-0">      
        
      {featuredPost && (
        <a 
          href={`/blog/${featuredPost.slug}/`}
          data-post-title={featuredPost.title.toLowerCase()}
          data-post-desc={featuredPost.description.toLowerCase()}
          data-post-category={featuredPost.category}
          class="blog-post-card group w-full border-b border-brand-secondary/10 py-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-6 transition-all duration-300 hover:bg-brand-secondary/[0.01]"
        >
          <div class="flex flex-col gap-3 max-w-2xl">
            <div class="flex items-center gap-3 text-[10px] tracking-wider text-brand-primary">
              <span class="p-2 border-b border-brand-primary text-left">FEATURED ESSAY</span>
              <span class="text-brand-secondary/30">•</span>
              <span class="lowercase font-mono">{featuredPost.category}</span>
            </div>
            <h2 class="text-2xl md:text-3xl font-accent font-bold tracking-tight text-brand-secondary group-hover:text-brand-primary transition-colors duration-300 lg:text-[40px]">
              {featuredPost.title}
            </h2>
            <p class="text-sm text-brand-secondary/80 font-secondary font-light leading-relaxed lg:text-[18px]">
              {featuredPost.description}
            </p>
          </div>
          
          <div class="flex flex-row md:flex-col items-baseline md:items-end gap-2 text-right font-mono text-xs text-brand-secondary/40 whitespace-nowrap">
            <span>{featuredPost.date}</span>
            <span class="hidden md:inline text-brand-secondary/20">|</span>
            <span>{featuredPost.readTime}</span>
          </div>
        </a>
      )}

      <div class="grid grid-cols-1 gap-0 border-b border-brand-secondary/10">
        {archivePosts.map((post, index) => (
          <a 
            href={`/blog/${post.slug}/`}
            data-post-title={post.title.toLowerCase()}
            data-post-desc={post.description.toLowerCase()}
            data-post-category={post.category}
            class={`blog-post-card group py-8 px-2 flex flex-col justify-between gap-8 border-brand-secondary/10 transition-all duration-300 hover:bg-brand-secondary/[0.01] -mr-px
              ${index % 2 === 0 ? 'border-b bg-brand-primary/[0.01]' : 'border-b'} last:border-b-0
            `}
          >
            <div class="flex items-center justify-between text-[10px] text-brand-secondary/40">
              <span class="uppercase font-mono bg-brand-secondary/5 px-2 py-0.5 border border-brand-secondary/10 rounded">
                {post.category}
              </span>
              <div class="flex gap-2">
                <span>{post.date}</span>
                <span>•</span>
                <span>{post.readTime}</span>
              </div>
            </div>

            <div class="flex flex-col gap-2">
              <h3 class="text-2xl font-accent font-bold tracking-tight text-brand-secondary group-hover:text-brand-primary transition-colors duration-300 lg:text-[30px]">
                {post.title}
              </h3>
              <p class="text-sm lg:text-[18px] text-brand-secondary/80 font-secondary font-light leading-relaxed">
                {post.description}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>

  </main>
</Layout>

<script>
  function setupSearchAndFilters() {
    const searchInput = document.getElementById('blog-search') as HTMLInputElement;
    const filterButtons = document.querySelectorAll('.filter-btn');
    const postCards = document.querySelectorAll('.blog-post-card');

    let currentSearchTerm = "";
    let currentCategory = "all";

    function filterPosts() {
      postCards.forEach((card) => {
        const title = card.getAttribute('data-post-title') || "";
        const desc = card.getAttribute('data-post-desc') || "";
        const category = card.getAttribute('data-post-category') || "";

        const matchesSearch = title.includes(currentSearchTerm) || desc.includes(currentSearchTerm);
        const matchesCategory = currentCategory === "all" || category === currentCategory;

        if (matchesSearch && matchesCategory) {
          // If the element is an archive grid item vs a main layout row card, handle fallback alignment cleanly
          if (card.classList.contains('grid')) {
             (card as HTMLElement).style.display = "grid";
          } else {
             (card as HTMLElement).style.display = "flex";
          }
        } else {
          (card as HTMLElement).style.display = "none";
        }
      });
    }

    // Input word listener
    searchInput?.addEventListener('input', (e) => {
      currentSearchTerm = (e.target as HTMLInputElement).value.toLowerCase();
      filterPosts();
    });

    // Tag toggle click listener
    filterButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        filterButtons.forEach(b => b.setAttribute('data-active', 'false'));
        btn.setAttribute('data-active', 'true');
        
        currentCategory = btn.getAttribute('data-category') || "all";
        filterPosts();
      });
    });
  }

  // Runs on initial view mount and matches Astro ViewTransition navigation updates
  setupSearchAndFilters();
  document.addEventListener('astro:after-swap', setupSearchAndFilters);
</script>