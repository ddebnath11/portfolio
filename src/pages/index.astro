---
import FeaturedProject from '../components/sections/FeaturedProject.astro';
import Hero from '../components/sections/Hero.astro';
import Layout from '../layouts/Layout.astro';
import FunText from '../components/sections/FunText.astro'

import { projectsList } from "../data/projects";

const project = projectsList[0];
---

<Layout title="Diptangshu Debnath - Home" pill="home">
   
  <Hero character_exists/>

  <FeaturedProject 

     project_title= {project.title}
     project_description={project.description}
     project_img_url={project.thumbnail}
     project_view_link={`/projects/${project.slug}`}
     project_github={project.github}
     project_launch={project.launch}

  
  
  
  
  />
  <FunText />
  
 


</Layout>